#!/bin/sh
export PATH="/usr/lib/postgresql/13/bin:$PATH"

# Read persisted JWT secret
export AGENTHOUND_JWT_SECRET=$(cat /data/.jwt_secret 2>/dev/null || echo "")
export AGENTHOUND_NEO4J_URI=bolt://127.0.0.1:7687
export AGENTHOUND_NEO4J_USER=neo4j
export AGENTHOUND_NEO4J_PASSWORD=agenthound
export AGENTHOUND_PG_URI="postgres://agenthound@127.0.0.1:5432/agenthound?sslmode=disable"
export AGENTHOUND_API_PORT=8080

# Wait for Neo4j bolt port
echo "[agenthound] Waiting for Neo4j..."
TRIES=0
while [ $TRIES -lt 30 ]; do
  if /opt/neo4j/bin/cypher-shell -u neo4j -p agenthound -a bolt://127.0.0.1:7687 "RETURN 1" >/dev/null 2>&1; then
    break
  fi
  TRIES=$((TRIES + 1))
  sleep 2
done

# Wait for PostgreSQL
echo "[agenthound] Waiting for PostgreSQL..."
TRIES=0
while [ $TRIES -lt 15 ]; do
  if gosu postgres pg_isready -h 127.0.0.1 -q 2>/dev/null; then
    break
  fi
  TRIES=$((TRIES + 1))
  sleep 1
done

echo "[agenthound] Starting AgentHound..."
exec /usr/local/bin/agenthound serve
