# ── Stage 1: Build React UI ──
FROM node:20-alpine AS ui-builder
WORKDIR /ui
COPY ui/package.json ui/package-lock.json ./
RUN npm ci
COPY ui/ .
RUN npm run build

# ── Stage 2: Build Go binary ──
FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
COPY --from=ui-builder /ui/dist ./internal/api/ui/dist
RUN CGO_ENABLED=0 GOOS=linux go build -o /bin/agenthound ./cmd/agenthound

# ── Stage 3: All-in-one runtime ──
# Bullseye has OpenJDK 11 (required by Neo4j 4.4) + PostgreSQL 13
FROM debian:bullseye-slim

ARG S6_OVERLAY_VERSION=3.1.6.2
ARG NEO4J_VERSION=4.4.37
ARG APOC_VERSION=4.4.0.40

# System packages: Java 11 (Neo4j 4.4 requires exactly Java 11), PostgreSQL, gosu, curl
RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-11-jre-headless \
    postgresql \
    gosu \
    curl \
    ca-certificates \
    procps \
    xz-utils \
    && rm -rf /var/lib/apt/lists/*

# s6-overlay for process supervision (installed after xz-utils)
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz /tmp/
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-x86_64.tar.xz /tmp/
RUN tar -C / -Jxpf /tmp/s6-overlay-noarch.tar.xz \
    && tar -C / -Jxpf /tmp/s6-overlay-x86_64.tar.xz \
    && rm /tmp/s6-overlay-*.tar.xz

# Neo4j 4.4 Community Edition
RUN curl -fsSL "https://dist.neo4j.org/neo4j-community-${NEO4J_VERSION}-unix.tar.gz" \
    | tar -xz -C /opt \
    && mv "/opt/neo4j-community-${NEO4J_VERSION}" /opt/neo4j \
    && mkdir -p /opt/neo4j/plugins

# APOC plugin (-all jar, required for apoc.merge.relationship + apoc.algo.dijkstra)
RUN curl -fsSL -o "/opt/neo4j/plugins/apoc-${APOC_VERSION}-all.jar" \
    "https://github.com/neo4j-contrib/neo4j-apoc-procedures/releases/download/${APOC_VERSION}/apoc-${APOC_VERSION}-all.jar"

# Neo4j configuration
COPY docker/neo4j.conf /opt/neo4j/conf/neo4j.conf

# s6 service definitions + init script
COPY docker/s6-rc/ /etc/s6-overlay/s6-rc.d/
COPY docker/init-db.sh /etc/s6-overlay/scripts/init-db
RUN chmod +x /etc/s6-overlay/scripts/init-db

# AgentHound binary
COPY --from=builder /bin/agenthound /usr/local/bin/agenthound

# Data volume
RUN mkdir -p /data
VOLUME /data

EXPOSE 8080

ENV S6_KEEP_ENV=1
ENV S6_BEHAVIOUR_IF_STAGE2_FAILS=2

ENTRYPOINT ["/init"]
