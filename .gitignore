bin/
coverage.out
*.exe
*.exe~
*.dll
*.so
*.dylib
.env
.env.*
server/ui/dist/
server/ui/node_modules/
*.tsbuildinfo
# Built UI assets are produced by `make ui-build`. Everything in this
# directory is ignored EXCEPT the committed .gitkeep marker, which exists
# so `go:embed all:ui/dist` in server/internal/api/server.go finds an
# embeddable directory on a fresh clone (Go requires the path to exist
# at compile time). When the real UI is missing, the server serves
# ui/fallback/index.html instead.
server/internal/api/ui/dist/*
!server/internal/api/ui/dist/.gitkeep
vendor/
*.test
__debug_bin*
.DS_Store
# v0.2 demo outputs — generated by scripts/seed-demo.sh from the
# docker-compose lab, not hand-edited. Re-running the script
# regenerates these.
testdata/demo/scan-output.json
testdata/demo/config-output.json
testdata/demo/loot-output.json
docker/demo/out/
# Standalone scan/loot files dropped in CWD by default.
/scan-*.json
/loot-*.json
# MkDocs build output — generated by `mkdocs build`, published via the Docs
# workflow. Never committed; the gh-pages deploy uploads it as an artifact.
/site/
